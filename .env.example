NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://crisisdesk:crisisdesk@localhost:5432/crisisdesk?schema=public

# Get a key from Google AI Studio. When omitted, deterministic fallback triage is used.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
AI_REQUIRED=false

# Replace every value below outside local development.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=8h
ADMIN_EMAIL=admin@crisisdesk.app
ADMIN_PASSWORD=change-me-now

CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
DUPLICATE_THRESHOLD=0.62
